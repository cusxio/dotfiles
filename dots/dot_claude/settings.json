{
  "permissions": {
    "deny": [
      "Bash(git branch -D *)",
      "Bash(git checkout .)",
      "Bash(git clean -f)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd)",
      "Bash(git clean -fd *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git push * --force *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git restore .)",

      "Bash(rm -rf *)",
      "Bash(ssh *)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)"
    ],
    "ask": [
      "Bash(chmod *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(rm *)"
    ],
    "allow": [
      "WebFetch",
      "WebSearch",

      "Bash(cd *)",
      "Bash(find *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(xargs *)",

      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",

      "Bash(bun *)",
      "Bash(moon *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(tsc *)",
      "Bash(yarn *)",

      "Bash(* --help *)",
      "Bash(* --version)"
    ],
    "defaultMode": "acceptEdits"
  }
}
